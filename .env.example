# ─────────────────────────────────────────────────────────────
#  MAP — .env.example
#  Copy this to .env and fill in real values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── APPLICATION ───────────────────────────────────────────────
APP_ENV=development          # development | staging | production
DEBUG=true
LOG_LEVEL=INFO

# ── DATABASE ──────────────────────────────────────────────────
DB_NAME=map_db
DB_USER=map_user
DB_PASSWORD=changeme
DB_HOST=postgres             # use 'localhost' when running outside Docker
DB_PORT=5432
DATABASE_URL=postgresql+asyncpg://map_user:changeme@postgres:5432/map_db
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# ── REDIS ─────────────────────────────────────────────────────
REDIS_HOST=redis             # use 'localhost' when running outside Docker
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── AUTHENTICATION ────────────────────────────────────────────
# Generate with: openssl genrsa -out private.pem 2048
#                openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nPASTE_KEY_HERE\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nPASTE_KEY_HERE\n-----END PUBLIC KEY-----"
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── AI PROVIDERS ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...
PRIMARY_AI_PROVIDER=openai   # openai | gemini
DEFAULT_MODEL=gpt-4o
FALLBACK_MODEL=mistral-7b-instruct
BENTOML_BASE_URL=http://map-bentoml:3001/v1

# ── AGENT CONFIGURATION ───────────────────────────────────────
PLANNER_TEMPERATURE=0.7
EXECUTOR_TEMPERATURE=0.2
ANALYZER_TEMPERATURE=0.1
EXECUTOR_MAX_ITERATIONS=10
ANALYZER_CONFIDENCE_THRESHOLD=0.70
MAX_TASK_RETRY_COUNT=3
TASK_TIMEOUT_SECONDS=3600

# ── RATE LIMITING ─────────────────────────────────────────────
RATE_LIMIT_FREE_RPM=100
RATE_LIMIT_PRO_RPM=500
RATE_LIMIT_ENTERPRISE_RPM=2000

# ── SECURITY ──────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=replace_with_32_byte_hex_string
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── EXTERNAL TOOLS (optional) ─────────────────────────────────
SERPAPI_KEY=                 # for web search tool
